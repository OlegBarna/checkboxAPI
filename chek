procedure TFmChek.btbtnSendReceiptCurlClick(Sender: TObject);
var
  Receipt: TReceipt;
  Response: string;
  ReceiptResponse: TReceiptResponse;
  Success: Boolean;
  CheckID: Integer;
  RetryCount: Integer;
  MaxRetries: Integer;
  TotalGoodsSum, TotalPaymentsSum: Integer;
  i: Integer;
  UserCancelled: Boolean;
  CurrentRetryCount: Integer;
  LHTMLContent: string;
  LPNGFileName: string;
  LQRCodeFileName: string;
  LTextContent: string;
  TotalFromGoods: Double;
  CheckSumFromDB: Double;
  ValidationError: string;
  JsonString: string;          // для можливого офлайн-збереження (поки не використовується)
  ReceiptIdAlreadySent: string; // для захисту від дублювання
begin
  // Перевірка, чи вже йде фіскалізація
  if FIsProcessingFiscalization then
  begin
    Log('Попередження: фіскалізація вже виконується');
    ShowMessage('Фіскалізація вже виконується. Зачекайте завершення...');
    Exit;
  end;

  // Валідація полів оплати перед фіскалізацією
  if not ValidatePaymentFields then
  begin
    Log('❌ Валідація полів оплати не пройдена');
    Exit;
  end;

  // Зберігаємо поточні значення з UI в БД
  SavePaymentToDB(DMMag.QChekKOD.AsInteger);

  UpdateAPIStatus(svProcessing);
  Receipt := nil;
  ReceiptResponse := nil;
  UserCancelled := False;
  LHTMLContent := '';
  LPNGFileName := '';
  LQRCodeFileName := '';
  LTextContent := '';
  ValidationError := '';
  ReceiptIdAlreadySent := '';

  CheckID := DMMag.QChekKOD.AsInteger;
  FDBManager.ValidateAndRepairCheckData(CheckID);

  FIsProcessingFiscalization := True;
  btbtnSendReceiptCurl.Enabled := False;
  Screen.Cursor := crHourGlass;

  try
    // Перевірка сум
    CheckSumFromDB := DMMag.QChekSUMMA.AsFloat;
    if not FDBManager.ValidateCheckSums(CheckID, TotalFromGoods, CheckSumFromDB) then
    begin
      ShowMessage(Format('Неспівпадіння сум:' + sLineBreak +
                        'Сума товарів: %.2f грн' + sLineBreak +
                        'Сума в чеку: %.2f грн' + sLineBreak +
                        'Перевірте коректність даних.',
                        [TotalFromGoods, CheckSumFromDB]));
      Exit;
    end;

    if not ValidateAPIState(True, True) then
      Exit;

    if not FDBManager.ValidateCheckForFiscalizationEx(CheckID, ValidationError) then
    begin
      if Pos('вже фіскалізований', ValidationError) > 0 then
      begin
        if MessageDlg('Чек вже фіскалізований',
            'Цей чек вже має фіскальний номер: ' + DMMag.QChekFISCAL_CODE.AsString +
            #13#10'Бажаєте відправити чек повторно?',
            mtConfirmation, [mbYes, mbNo], 0) <> mrYes then
        begin
          UserCancelled := True;
          Log('Користувач відмовився від повторної фіскалізації чека ' + DMMag.QChekFISCAL_CODE.AsString);
          Exit;
        end;
      end
      else
      begin
        ShowMessage(ValidationError);
        Exit;
      end;
    end;

    if not IsShiftReadyForFiscalization then
    begin
      Log('Зміна не готова для фіскалізації');
      Exit;
    end;

    if not IsCashRegisterOnline then
    begin
      Log('Каса в офлайн-режимі - фіскалізація неможлива');
      Exit;
    end;

    // Перевірка інтернету
    if not FReceiptAPI.CheckConnectivityCurl(Response) then
    begin
      UpdateAPIStatus(svOffline);
      Log('Відсутнє зʼєднання з інтернетом: ' + Response);
      ShowMessage('Відсутнє підключення до інтернету! Фіскалізація неможлива.');
      Exit;
    end
    else
      Log('Зʼєднання з інтернетом перевірено успішно');

    // Призначення директорій
    FReceiptAPI.ReceiptsDirectory := receiptspath;
    FReceiptAPI.TempDirectory := temppath;
    if not DirectoryExists(FReceiptAPI.ReceiptsDirectory) then
      if not ForceDirectories(FReceiptAPI.ReceiptsDirectory) then
      begin
        Log('❌ Не вдалося створити директорію для чеків: ' + FReceiptAPI.ReceiptsDirectory);
        ShowMessage('Не вдалося створити папку для збереження чеків. Перевірте права доступу.');
        Exit;
      end;
    if not DirectoryExists(FReceiptAPI.TempDirectory) then
      if not ForceDirectories(FReceiptAPI.TempDirectory) then
      begin
        Log('❌ Не вдалося створити тимчасову директорію: ' + FReceiptAPI.TempDirectory);
        ShowMessage('Не вдалося створити тимчасову папку. Перевірте права доступу.');
        Exit;
      end;

    CurrentRetryCount := FDBManager.GetFiscalRetryCount(CheckID);

    try
      Log('=== ПОЧАТОК ФІСКАЛІЗАЦІЇ ЧЕКА ===');
      Log('ID чека: ' + IntToStr(CheckID));
      Log('Номер чека: ' + DMMag.QChekNOMER.AsString);
      Log('ID зміни: ' + FReceiptAPI.CurrentShiftId);
      Log('ID каси: ' + FReceiptAPI.CurrentCashRegisterId);
      Log('Початкова кількість спроб: ' + IntToStr(CurrentRetryCount));

      FDBManager.LogDatabaseState;

      if not DMMag.QChek.Active or not DMMag.QNData.Active then
      begin
        Log('❌ ПОМИЛКА: Запити до БД не активні!');
        ShowMessage('Помилка: втрачено звʼязок з базою даних. Спробуйте ще раз.');
        Exit;
      end;

      // ---------- СТВОРЕННЯ ОБ'ЄКТА ЧЕКА (НОВА ВЕРСІЯ) ----------
      Receipt := TReceipt.Create;
      FillMandatoryReceiptFields(Receipt, CheckID);  // використовує оновлені FillGoodsFromDatabase, FillPaymentsFromDatabase

      Log('=== ФІНАЛЬНА ПЕРЕВІРКА СТРУКТУРИ ЧЕКА ===');
      Log('Receipt.TotalSum: ' + IntToStr(Receipt.TotalSum) + ' коп');
      Log('Receipt.TotalPayment: ' + IntToStr(Receipt.TotalPayment) + ' коп');
      Log('Receipt.Rest: ' + IntToStr(Receipt.Rest) + ' коп');

      if Receipt.TotalPayment < Receipt.TotalSum then
      begin
        Log('❌ КРИТИЧНА ПОМИЛКА: TotalPayment < TotalSum!');
        Log('🔄 Спроба автоматичного виправлення сум...');
        Receipt.TotalPayment := Receipt.TotalSum;
        Receipt.Rest := 0;
        if Length(Receipt.Payments) > 0 then
        begin
          Receipt.Payments[0].Value := Receipt.TotalSum;
          Log('✅ Суми автоматично виправлено');
        end
        else
        begin
          ShowMessage('Критична помилка: сума оплати менша за загальну суму чека. Додайте оплату.');
          Exit;
        end;
      end
      else
        Log('✅ Структура чека коректна');

      // Перевірка сум товарів і оплат
      TotalGoodsSum := 0;
      for i := 0 to High(Receipt.Goods) do
        if Assigned(Receipt.Goods[i]) then
          TotalGoodsSum := TotalGoodsSum + Receipt.Goods[i].TotalSum;
      Log('Сума товарів: ' + FloatToStrF(TotalGoodsSum/100, ffNumber, 10, 2) + ' грн');

      TotalPaymentsSum := 0;
      for i := 0 to High(Receipt.Payments) do
        if Assigned(Receipt.Payments[i]) then
          TotalPaymentsSum := TotalPaymentsSum + Receipt.Payments[i].Value;
      Log('Сума оплат: ' + FloatToStrF(TotalPaymentsSum/100, ffNumber, 10, 2) + ' грн');

      if TotalGoodsSum <> TotalPaymentsSum then
      begin
        Log('❌ ПОМИЛКА: Сума товарів ≠ Сумі оплат!');
        if TotalPaymentsSum < TotalGoodsSum then
        begin
          Log('🔄 Автоматично виправляємо оплату...');
          if Length(Receipt.Payments) > 0 then
          begin
            Receipt.Payments[0].Value := TotalGoodsSum;
            Receipt.TotalPayment := TotalGoodsSum;
            Receipt.Rest := 0;
            Log('✅ Оплату автоматично виправлено');
          end;
        end;
        ShowMessage('Увага: Сума товарів (' + FloatToStrF(TotalGoodsSum/100, ffNumber, 10, 2) +
                   ' грн) не дорівнює сумі оплат (' + FloatToStrF(TotalPaymentsSum/100, ffNumber, 10, 2) + ' грн)' +
                   sLineBreak + 'Спроба автоматичного виправлення...');
      end
      else
        Log('✅ Суми збігаються');

      // ---------- ФОРМУВАННЯ JSON ДЛЯ МОЖЛИВОГО ОФЛАЙН-ЗБЕРЕЖЕННЯ ----------
      // (поки не використовується, але зберігаємо змінну для майбутнього)
      JsonString := '';
      try
        with FReceiptAPI.BuildJsonDataCorrected(Receipt) do
          JsonString := AsJSON;
      except
        on E: Exception do
          Log('⚠️ Не вдалося отримати JSON для офлайн-збереження: ' + E.Message);
      end;

      // Оновлюємо статус в БД
      FDBManager.UpdateFiscalStatusInDB(CheckID, 'SENT', '', '', '', '', -1, '', '', CurrentRetryCount);

      // ---------- ВІДПРАВКА ЧЕКА З ПОВТОРНИМИ СПРОБАМИ ----------
      MaxRetries := 3;
      RetryCount := CurrentRetryCount;
      Success := False;
      ReceiptIdAlreadySent := ''; // буде заповнено, якщо сервер створив чек

      while RetryCount < MaxRetries do
      begin
        Log(Format('Спроба фіскалізації %d з %d (всього спроб: %d)',
            [RetryCount - CurrentRetryCount + 1, MaxRetries - CurrentRetryCount, RetryCount + 1]));

        // Відправка (використовує оновлений SendReceiptCurl)
        Success := FReceiptAPI.SendReceiptCurl(Receipt, Response, ReceiptResponse);

        if Success then
        begin
          Log('✅ Відповідь сервера отримана успішно');
          if Assigned(ReceiptResponse) then
            ReceiptIdAlreadySent := ReceiptResponse.Id; // зберігаємо ID для захисту від дублів
          if RetryCount > CurrentRetryCount then
            FDBManager.ResetFiscalRetryCount(CheckID);
          Break;
        end
        else
        begin
          Log('❌ Помилка спроби ' + IntToStr(RetryCount + 1) + ': ' + Response);

          // Помилка податкових груп – не повторюємо
          if (Pos('податк', LowerCase(Response)) <> 0) or (Pos('tax', LowerCase(Response)) <> 0) then
          begin
            Log('⚠️ Проблема з податковими групами - потрібне налаштування в кабінеті Checkbox');
            ShowMessage('Помилка податкових груп:' + sLineBreak +
                       'Необхідно налаштувати податкові ставки в кабінеті Checkbox.' + sLineBreak +
                       'Деталі: ' + Copy(Response, 1, 150));
            Break;
          end;

          // Перевіряємо, чи варто повторювати (з урахуванням вже створеного ID)
          if not ShouldRetryFiscalization(CheckID, Response, RetryCount, ReceiptIdAlreadySent) then
          begin
            Log('⏹️  Подальші спроби припинено за логікою ShouldRetryFiscalization');
            Break;
          end;

          if Pos('offline', LowerCase(Response)) > 0 then
          begin
            Log('⚠️ Каса перейшла в офлайн-режим під час фіскалізації');
            ShowMessage('Каса перейшла в офлайн-режим. Спробуйте пізніше.');
            Break;
          end;

          if Pos('shift', LowerCase(Response)) > 0 then
          begin
            Log('⚠️ Проблема зі зміною - можливо, зміна закрита або неактивна');
            ShowMessage('Проблема зі зміною. Перевірте, чи зміна відкрита.');
            Break;
          end;

          Inc(RetryCount);
          if RetryCount < MaxRetries then
          begin
            FDBManager.SetFiscalRetryCount(CheckID, RetryCount);
            Log('🕒 Повторна спроба через 2 секунди...');
            Sleep(2000);
          end;
        end;
      end;

      // ---------- ОБРОБКА РЕЗУЛЬТАТУ ----------
      if Success and Assigned(ReceiptResponse) then
      begin
        Log('✅ Запит чека успішно відправлено!');
        Log('ID чека в Checkbox: ' + ReceiptResponse.Id);
        Log('Початковий статус: ' + ReceiptStatusToString(ReceiptResponse.Status));
        Log('Фіскальний номер: ' + ReceiptResponse.FiscalCode);

        try
          FDBManager.LogDatabaseState;
          FDBManager.SafeCommitAndReopenConnection;
          FDBManager.LogDatabaseState;
        except
          on E: Exception do
            Log('❌ Помилка збереження даних в БД: ' + E.Message);
        end;

        HandleSuccessfulFiscalization(CheckID, Receipt, ReceiptResponse);

        // Отримання візуалізації
        Log('=== ОТРИМАННЯ ВІЗУАЛІЗАЦІЇ ЧЕКА ===');
        if FReceiptAPI.GetReceiptPNG(ReceiptResponse.Id, LPNGFileName, 30, 58, 75) then
        begin
          Log('✓ PNG отримано: ' + ExtractFileName(LPNGFileName));
          if FileExists(LPNGFileName) then
          begin
            ShowCheck(LPNGFileName);
            if MessageDlg('Чек', 'Надрукувати чек?', mtConfirmation, [mbYes, mbNo], 0) = mrYes then
              PrintCheckCustom(LPNGFileName, FPrinterName, FPageLeft, FPageTop, FPageWidth, FPageScale);
          end;
        end
        else
          Log('✗ Помилка отримання PNG: ' + FReceiptAPI.LastError);

        if FReceiptAPI.GetReceiptQRCode(ReceiptResponse.Id, LQRCodeFileName) then
          Log('✓ QR-код отримано');
        if FReceiptAPI.GetReceiptHTML(ReceiptResponse.Id, LHTMLContent) then
          SaveStringToFile(FReceiptAPI.ReceiptsDirectory + '/receipt_' + ReceiptResponse.Id + '.html', LHTMLContent);
        if FReceiptAPI.GetReceiptText(ReceiptResponse.Id, LTextContent) then
          SaveStringToFile(FReceiptAPI.ReceiptsDirectory + '/receipt_' + ReceiptResponse.Id + '.txt', LTextContent);

        Log('=== ЗАВЕРШЕННЯ ВІЗУАЛІЗАЦІЇ ===');
      end
      else
      begin
        Log('❌ Помилка відправки після ' + IntToStr(RetryCount - CurrentRetryCount + 1) + ' спроб: ' + Response);
        FDBManager.SetFiscalRetryCount(CheckID, RetryCount);
        HandleFailedFiscalization(CheckID, Response);

        // ---------- ТИМЧАСОВО ОФЛАЙН-ЧЕРГА ВІДКЛЮЧЕНА ----------
        if IsNetworkError(Response) then
        begin
          ShowMessage('Помилка мережі після ' + IntToStr(RetryCount - CurrentRetryCount + 1) + ' спроб:' + sLineBreak +
                     'Не вдалося зв''язатися з сервером Checkbox.' + sLineBreak +
                     'Чек НЕ збережено в офлайн-чергу (функціонал тимчасово відключений).');
          Log('⚠️ Офлайн-збереження відключено. Чек не збережено.');
          // Коли будете готові впровадити офлайн – розкоментуйте наступний блок:
          {
          if MessageDlg('Фіскалізація неможлива', ... , mtConfirmation, [mbYes, mbNo], 0) = mrYes then
            SaveReceiptToOfflineQueue(CheckID, Receipt, JsonString, Response);
          }
        end
        else if Pos('validation', LowerCase(Response)) > 0 then
          ShowMessage('Помилка валідації даних:' + sLineBreak +
                     'Перевірте коректність даних чека.' + sLineBreak +
                     Copy(Response, 1, 200))
        else
          ShowMessage('Помилка фіскалізації: ' + Copy(Response, 1, 200));
      end;

    except
      on E: Exception do
      begin
        Log('💥 Виняток при фіскалізації: ' + E.Message);
        Log('Тип: ' + E.ClassName);
        if not UserCancelled then
          HandleFiscalizationException(CheckID, E);
        ShowMessage('Критична помилка: ' + E.Message);
      end;
    end;

  finally
    if not UserCancelled then
    begin
      Log('Очищення ресурсів...');
      if Assigned(Receipt) then FreeAndNil(Receipt);
      if Assigned(ReceiptResponse) then FreeAndNil(ReceiptResponse);
    end
    else
      Log('Користувач відмовився – очищення не потрібне');

    btbtnSendReceiptCurl.Enabled := True;
    Screen.Cursor := crDefault;
    FIsProcessingFiscalization := False;

    Log('=== ЗАВЕРШЕННЯ ФІСКАЛІЗАЦІЇ ===');
    UpdateAllStatuses;
  end;
end;


// Для внесення готівки
procedure TFmChek.btnCashInClick(Sender: TObject);
var
  Response: string;
  ReceiptResponse: TReceiptResponse;
  Amount: Integer;
begin
  // 1. Перевірка стану API та каси
  if not ValidateAPIState(False, True) then
    Exit;

  // 2. Отримуємо суму з поля введення
  Amount := GetAmountInKopiyky;

  if Amount <= 0 then
  begin
    ShowMessage('Введіть коректну суму!');
    fseAmount.SetFocus;
    Exit;
  end;

  // 3. Перевірка — для внесення не потрібно перевіряти баланс
  //    (готівку завжди можна внести, якщо зміна відкрита)

  // 4. Підтвердження операції
  if MessageDlg(
    'Підтвердження внесення готівки',
    'Ви впевнені, що хочете внести ' + FormatFloat('0.00', Amount / 100) + ' грн в касу?',
    mtConfirmation, [mbYes, mbNo], 0
  ) <> mrYes then
    Exit;

  // 5. Логування операції
  Log('Операція внесення готівки: ' + FormatFloat('0.00', Amount / 100) + ' грн');

  // 6. Виконуємо операцію
  if FReceiptAPI.CashIncome(Amount, '', Response, ReceiptResponse) then
  begin
    // 7. Успіх — оновлюємо баланс
    UpdateBalanceAfterOperation;
    ShowMessage(
      'Готівку внесено успішно!' + sLineBreak +
      sLineBreak +
      'ID чека: ' + ReceiptResponse.Id + sLineBreak +
      'Сума: ' + FormatFloat('0.00', Amount / 100) + ' грн' + sLineBreak +
      'Баланс в касі: ' + FormatFloat('0.00', FCurrentBalance / 100) + ' грн'
    );

    fseAmount.Value := 0;
  end
  else
  begin
    ShowMessage('Помилка внесення готівки:' + sLineBreak + Response);
  end;
  UpdateAllStatuses;
  // 8. Очищення та оновлення UI
  if Assigned(ReceiptResponse) then
    FreeAndNil(ReceiptResponse);
end;


// Для винесення готівки
procedure TFmChek.btnCashOutClick(Sender: TObject);
var
  Response: string;
  ReceiptResponse: TReceiptResponse;
  Amount: Integer;
begin
  // 1. Перевірка стану API та каси
  if not ValidateAPIState(False, True) then
    Exit;

  // 2. Отримуємо суму з поля введення
  Amount := GetAmountInKopiyky;

  if Amount <= 0 then
  begin
    ShowMessage('Введіть коректну суму!');
    fseAmount.SetFocus;
    Exit;
  end;

  // 3. Перевірка балансу — використовуємо FCurrentBalance (без API-запиту!)
  // FCurrentBalance оновлюється при відкритті зміни та після кожної операції
  if FCurrentBalance <= 0 then
  begin
    ShowMessage(
      'Недостатньо коштів в касі для винесення!' + sLineBreak +
      sLineBreak +
      'Поточний баланс: ' + FormatFloat('0.00', FCurrentBalance / 100) + ' грн' + sLineBreak +
      sLineBreak +
      'Перевірте, чи відкрита зміна та чи є готівка в касі.'
    );
    Exit;
  end;

  if Amount > FCurrentBalance then
  begin
    ShowMessage(
      'Недостатньо коштів в касі для винесення!' + sLineBreak +
      sLineBreak +
      'Доступно: ' + FormatFloat('0.00', FCurrentBalance / 100) + ' грн' + sLineBreak +
      'Спроба винесення: ' + FormatFloat('0.00', Amount / 100) + ' грн'
    );
    Exit;
  end;

  // 4. Підтвердження операції
  if MessageDlg(
    'Підтвердження винесення готівки',
    'Ви впевнені, що хочете винести ' + FormatFloat('0.00', Amount / 100) + ' грн з каси?',
    mtConfirmation, [mbYes, mbNo], 0
  ) <> mrYes then
    Exit;

  // 5. Логування операції (опис НЕ передається в API)
  Log('Операція винесення готівки: ' + FormatFloat('0.00', Amount / 100) + ' грн');

  // 6. Виконуємо операцію
  //    Параметр ADescription = '' — API /receipts/service не підтримує description
  if FReceiptAPI.CashOutcome(Amount, '', Response, ReceiptResponse) then
  begin
    // 7. Успіх — оновлюємо баланс
    UpdateBalanceAfterOperation;
    ShowMessage(
      'Готівку винесено успішно!' + sLineBreak +
      sLineBreak +
      'ID чека: ' + ReceiptResponse.Id + sLineBreak +
      'Сума: ' + FormatFloat('0.00', Amount / 100) + ' грн' + sLineBreak +
      'Залишок в касі: ' + FormatFloat('0.00', FCurrentBalance / 100) + ' грн'
    );

    fseAmount.Value := 0;
  end
  else
  begin
    ShowMessage('Помилка винесення готівки:' + sLineBreak + Response);
  end;
  UpdateAllStatuses;
  // 8. Очищення та оновлення UI
  if Assigned(ReceiptResponse) then
    FreeAndNil(ReceiptResponse);
end;


