procedure TFmChek.UpdateStatusBar(StatusType: TStatusType; StatusValue: TStatusValue;
                                  AdditionalText: string = '');
var
  FullText: string;
begin
  if not Assigned(StatusBar1) or (StatusBar1.Panels.Count < 4) then
    Exit;

  // Формуємо текст з емодзі
  FullText := StatusEmoji[StatusValue] + ' ' + StatusText[StatusValue];

  // Додаємо додатковий текст якщо є
  if AdditionalText <> '' then
    FullText := FullText + ' ' + AdditionalText;

  // Оновлюємо відповідну панель
  case StatusType of
    stAPI:         StatusBar1.Panels[0].Text := 'API: ' + FullText;
    stCashier:     StatusBar1.Panels[1].Text := 'Касир: ' + FullText;
    stCashRegister:StatusBar1.Panels[2].Text := 'Каса: ' + FullText;
    stShift:       StatusBar1.Panels[3].Text := 'Зміна: ' + FullText;
  end;

  // Оновлюємо інтерфейс
  Application.ProcessMessages;
end;


