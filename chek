procedure TFmChek.SaveReceiptToOfflineQueue(CheckID: Integer; Receipt: TReceipt;
  const JsonString, ErrorResponse: string);
var
  ReceiptUUID: string;
begin
  try
    if Assigned(Receipt) then
      ReceiptUUID := Receipt.Id
    else
      ReceiptUUID := '';

    DMMag.SQLQ.SQL.Text :=
      'INSERT INTO OFFLINE_RECEIPTS_QUEUE (' +
      '  CHECK_ID, RECEIPT_UUID, RECEIPT_JSON, ERROR_MSG, ' +
      '  CREATED_AT, STATUS, RETRY_COUNT) ' +
      'VALUES (' +
      '  :CHECK_ID, :RECEIPT_UUID, :RECEIPT_JSON, :ERROR_MSG, ' +
      '  CURRENT_TIMESTAMP, ''PENDING'', 0)';

    DMMag.SQLQ.ParamByName('CHECK_ID').AsInteger := CheckID;
    DMMag.SQLQ.ParamByName('RECEIPT_UUID').AsString := ReceiptUUID;
    DMMag.SQLQ.ParamByName('RECEIPT_JSON').AsString := JsonString;
    DMMag.SQLQ.ParamByName('ERROR_MSG').AsString := Copy(ErrorResponse, 1, 500);
    DMMag.SQLQ.ExecSQL;

    Log('Чек ' + IntToStr(CheckID) + ' (UUID: ' + Copy(ReceiptUUID, 1, 8) +
        '...) додано до офлайн-черги');
  except
    on E: Exception do
    begin
      Log('❌ Помилка збереження в офлайн-чергу: ' + E.Message);
      raise;
    end;
  end;
end;

function TFmChek.ShouldRetryFiscalization(ACheckID: Integer; const AResponse: string;
  CurrentRetry: Integer; const ReceiptIdAlreadySent: string): Boolean;
begin
  if ReceiptIdAlreadySent <> '' then
  begin
    Result := False;
    Log('⛔ Чек вже створений на сервері (ID: ' + ReceiptIdAlreadySent +
        '). Повторна спроба заборонена.');
    Exit;
  end;

  if IsNetworkError(AResponse) then
    Result := CurrentRetry < 3
  else if (Pos('validation', LowerCase(AResponse)) > 0) or
          (Pos('валідації', AResponse) > 0) then
    Result := CurrentRetry < 1
  else if (Pos('shift', LowerCase(AResponse)) > 0) or
          (Pos('offline', LowerCase(AResponse)) > 0) then
    Result := CurrentRetry < 1
  else
    Result := CurrentRetry < 2;

  if not Result then
    Log('Досягнуто максимальну кількість спроб. Поточні: ' + IntToStr(CurrentRetry));
end;

function TFmChek.IsNetworkError(const AResponse: string): Boolean;
begin
  Result := (Pos('timeout', LowerCase(AResponse)) > 0) or
            (Pos('network', LowerCase(AResponse)) > 0) or
            (Pos('connection', LowerCase(AResponse)) > 0) or
            (Pos('connect', LowerCase(AResponse)) > 0) or
            (Pos('host', LowerCase(AResponse)) > 0) or
            (Pos('unreachable', LowerCase(AResponse)) > 0);
end;


