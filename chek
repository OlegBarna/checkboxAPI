procedure TFmChek.UpdateAllStatuses;
begin
  if not UseCheckboxAPI then
  begin
    UpdateAPIStatus(svDisabled);
    UpdateCashierStatus(svDisabled);
    UpdateCashRegisterStatus(svDisabled);
    UpdateShiftStatus(svDisabled);
    Exit;
  end;

  if not Assigned(FReceiptAPI) then
  begin
    UpdateAPIStatus(svUnknown);
    UpdateCashierStatus(svUnknown);
    UpdateCashRegisterStatus(svUnknown);
    UpdateShiftStatus(svUnknown);
    Exit;
  end;

  // Автоматичне оновлення на основі поточного стану
  if FReceiptAPI.IsTokenValid then
    UpdateCashierStatus(svOnline)
  else
    UpdateCashierStatus(svUnknown);

  // Інші статуси оновлюються окремо
end;



procedure TFmChek.InitializeCheckboxAPI;
var
  Response, ShiftId, AuthResponse: string;
  ShiftStatus: TShiftStatus;
  i: Integer;
begin
  // Початкові статуси
  UpdateAPIStatus(svProcessing, 'Ініціалізація...');
  UpdateCashierStatus(svUnknown);
  UpdateCashRegisterStatus(svUnknown);
  UpdateShiftStatus(svUnknown);

  Log('Перевірка стану Checkbox API...');

  // Базова перевірка API
  if not ValidateAPIState(False, False) then
  begin
    Log('❌ Не вдалося ініціалізувати API або авторизуватися');
    UpdateAPIStatus(svError, 'Помилка ініціалізації');
    UpdateCashierStatus(svError, 'Помилка авторизації');
    Exit;
  end;

  Log('API успішно ініціалізовано та авторизовано');
  UpdateAPIStatus(svOnline);
  UpdateCashierInfo;
  LoadCashRegisterPreferences;

  // --- КАСА ---
  if FReceiptAPI.CurrentCashRegisterId = '' then
  begin
    Log('Спроба автоматичного вибору оптимальної каси...');
    UpdateCashRegisterStatus(svProcessing, 'Автоматичний вибір...');

    if InitializeOptimalCashRegister(Response) then
    begin
      Log('Касу автоматично обрано: ' + Copy(FReceiptAPI.CurrentCashRegisterId, 1, 8) + '...');
      SaveCashRegisterPreferences;
      RefreshCashRegisterList;
    end
    else
    begin
      Log('Не вдалося автоматично обрати касу: ' + Response);
      UpdateCashRegisterStatus(svError, 'Не вдалося обрати');
      RefreshCashRegisterList;

      if Length(FCashRegisters) > 0 then
        ShowMessage('Не вдалося автоматично обрати касу.' + sLineBreak +
                   'Будь ласка, виберіть касу вручну зі списку.')
      else
        ShowMessage('Не вдалося отримати список кас. Перевірте зʼєднання.');
    end;
  end
  else
  begin
    Log('Використовуємо збережену касу: ' + Copy(FReceiptAPI.CurrentCashRegisterId, 1, 8) + '...');
    UpdateCashRegisterStatus(svReady, 'Збережена каса');
    RefreshCashRegisterList;
  end;

  // Перевірка ID каси
  if FReceiptAPI.CurrentCashRegisterId = '' then
  begin
    Log('⚠️ УВАГА: ID каси не встановлено! Операції з готівкою будуть неможливі.');
    UpdateCashRegisterStatus(svError, 'ID не встановлено');
  end
  else
    Log('✅ ID каси встановлено: ' + Copy(FReceiptAPI.CurrentCashRegisterId, 1, 8) + '...');

  // --- ЗМІНА ---
  ShiftId := FReceiptAPI.LoadShiftFromFile;
  if ShiftId <> '' then
  begin
    Log('Знайдено збережену зміну: ' + Copy(ShiftId, 1, 8) + '...');
    UpdateShiftStatus(svProcessing, 'Перевірка...');

    if FReceiptAPI.GetShiftStatusCurl(ShiftId, AuthResponse, ShiftStatus) and Assigned(ShiftStatus) then
    begin
      try
        if ShiftStatus.Status = 'OPENED' then
        begin
          SynchronizeShiftId(ShiftStatus.Id);
          btnCloseShiftSimpleCurl.Enabled := True;
          UpdateShiftStatus(svOpened, '№' + IntToStr(ShiftStatus.Serial));

          Log('Зміну успішно відновлено: ' + ShiftStatus.Id + sLineBreak +
              'Номер: ' + IntToStr(ShiftStatus.Serial) + sLineBreak +
              'Відкрита: ' + DateTimeToStr(ShiftStatus.OpenedAt));

          if Assigned(ShiftStatus.Balance) then
          begin
            FCurrentBalance := ShiftStatus.Balance.Balance;
            UpdateCashBalance;
            Log(Format('Баланс відновленої зміни: %.2f грн', [FCurrentBalance / 100]));
          end;
        end
        else
        begin
          Log('Збережена зміна неактивна. Статус: ' + ShiftStatus.Status);
          UpdateShiftStatus(svClosed, 'Неактивна');
          ClearShiftStateFile;
          ShowMessage('Збережена зміна вже закрита або неактивна. Статус: ' + ShiftStatus.Status);
        end;
      finally
        FreeAndNil(ShiftStatus);
      end;
    end
    else
    begin
      Log('Не вдалося перевірити статус зміни: ' + AuthResponse);
      UpdateShiftStatus(svError, 'Помилка перевірки');

      if MessageDlg('Помилка перевірки',
          'Не вдалося перевірити статус збереженої зміни.' + sLineBreak +
          'Можливі причини:' + sLineBreak +
          '- Втрачено зв''язок з сервером' + sLineBreak +
          '- Зміна була видалена' + sLineBreak +
          '- Проблеми з авторизацією' + sLineBreak + sLineBreak +
          'Видалити збережений стан?',
          mtWarning, [mbYes, mbNo], 0) = mrYes then
      begin
        ClearShiftStateFile;
        Log('Користувач видалив збережений стан зміни');
      end
      else
        Log('Користувач зберіг стан зміни для подальших спроб');
    end;
  end
  else
  begin
    Log('Збережена зміна не знайдена');
    UpdateShiftStatus(svClosed, 'Не знайдена');
  end;

  // Активація кнопок
  if FReceiptAPI.CurrentShiftId <> '' then
  begin
    btnCloseShiftSimpleCurl.Enabled := True;
    Log('Інтерфейс налаштовано для роботи зі зміною');
  end;

  UpdateAllStatuses;
end;


function TFmChek.PaymentTypeIndexToStr(Index: Integer): string;
begin
  case Index of
    0: Result := 'CASH';
    1: Result := 'CASHLESS';
    2: Result := 'OTHER';
  else
    Result := 'CASH';
  end;
end;

// ===== ВИПРАВЛЕНИЙ PaymentTypeStrToIndex з підтримкою 'CARD' =====
function TFmChek.PaymentTypeStrToIndex(const S: string): Integer;
begin
  if S = 'CASH' then Result := 0
  else if (S = 'CASHLESS') or (S = 'CARD') then Result := 1   // Додано підтримку 'CARD'
  else if S = 'OTHER' then Result := 2
  else Result := 0; // За замовчуванням готівка
end;

function TFmChek.SubTypeIndexToCode(Index: Integer): Integer;
begin
  // Index 0 → CST_CARD (1), Index 1 → CST_INTERNET_BANKING (2), ...
  Result := Index + 1;
  if (Result < 1) or (Result > 17) then Result := 1;
end;

function TFmChek.SubTypeCodeToIndex(Code: Integer): Integer;
begin
  Result := Code - 1;
  if (Result < 0) or (Result > 16) then Result := 0;
end;

// ===== ВИПРАВЛЕНИЙ UpdatePaymentUIVisibility =====
procedure TFmChek.UpdatePaymentUIVisibility;
var
  SubType: Integer;
begin
  if cmbPaymentType.ItemIndex <> 1 then
  begin
    // Не "Безготівка" — ховаємо все додаткове
    cmbCashlessSubType.Visible := False;
    gbPaymentDetails.Visible := False;
    Exit;
  end;

  // "Безготівка" — показуємо підтип
  cmbCashlessSubType.Visible := True;

  SubType := SubTypeIndexToCode(cmbCashlessSubType.ItemIndex);

  // Визначаємо, чи потрібні додаткові поля
  case SubType of
    1, 3: // Картка, Інтернет еквайринг
      begin
        gbPaymentDetails.Visible := True;
        ShowCardDetails(True);
        ShowInternetBankingDetails(False);
      end;

    2: // Інтернет-банкінг
      begin
        gbPaymentDetails.Visible := True;
        ShowCardDetails(False);
        ShowInternetBankingDetails(True);
      end;

    4..8: // Інтегратори — опціонально AuthCode/RRN
      begin
        gbPaymentDetails.Visible := True;
        ShowCardDetails(False); // можна True, якщо потрібні поля картки
        ShowInternetBankingDetails(False);
        // Додатково можна показати поля AuthCode/RRN окремо
      end;

    9: // Подарунковий сертифікат
      begin
        gbPaymentDetails.Visible := True;
        ShowCardDetails(True); // Маска = номер сертифіката
        ShowInternetBankingDetails(False);
      end;

    10..17: // Талон та інші — без додаткових полів
      begin
        gbPaymentDetails.Visible := False;
        ShowCardDetails(False);
        ShowInternetBankingDetails(False);
      end;
  end;
end;

