procedure TFmChek.FillMandatoryReceiptFields(Receipt: TReceipt; CheckID: Integer);
begin
  Receipt.Id := FReceiptAPI.GenerateUUID;
  Log('Згенеровано Receipt.Id: ' + Receipt.Id);

  Receipt.CashierName := FCashierNameFromIni;
  Receipt.Departament := FDepartamentFromIni;
  Receipt.OrderId := '';

  // Тип чека - enum з ReceiptWebAPI
  Receipt.ReceiptType := rtSell;

  // Округлення в копійках (0 = без округлення)
  Receipt.RoundingSum := 0;

  FillGoodsFromDatabase(Receipt, CheckID);

  Receipt.TotalSum := CalculateTotalSum(Receipt.Goods);
  Receipt.Sum := Receipt.TotalSum;

  Log('Загальна сума: ' +
      FloatToStrF(Receipt.TotalSum/100, ffNumber, 10, 2) + ' грн');

  FillPaymentsFromDatabase(Receipt, CheckID);

  // Rounding: Boolean - legacy, не використовується в JSON
  Receipt.Rounding := False;

  Log('Заповнено обовʼязкові поля. OrderId: "" (буде null в JSON)');
end;


procedure TFmChek.FillGoodsFromDatabase(Receipt: TReceipt; CheckID: Integer);
var
  i: Integer;
  Good: TGood;
  GoodItem: TGoodItem;
  TaxGroup: Integer;
  BarcodeStr: string;
  TovarKod: Integer;
begin
  SetLength(Receipt.Goods, 0);

  DMMag.QNData.First;
  i := 0;
  while not DMMag.QNData.Eof do
  begin
    // Визначаємо податкову групу
    TaxGroup := DetermineTaxGroupForProduct(DMMag.QNData.FieldByName('TOVAR').AsString);

    // ВАЛІДАЦІЯ: перевірка, що податкова група існує в Checkbox
    if not IsTaxGroupValid(TaxGroup) then
    begin
      raise Exception.CreateFmt(
        'Товар "%s" має невідому податкову групу %d. ' +
        'Налаштуйте податкові ставки в кабінеті Checkbox.',
        [DMMag.QNData.FieldByName('NAZVA').AsString, TaxGroup]);
    end;

    // === ОТРИМАННЯ ШТРИХ-КОДУ З ТАБЛИЦІ TOVAR ===
    BarcodeStr := '';
    TovarKod := DMMag.QNData.FieldByName('TOVAR').AsInteger;
    try
      // Шукаємо штрих-код в таблиці TOVAR через окремий запит
      DMMag.SQLQ.Close;
      DMMag.SQLQ.SQL.Text :=
        'SELECT TKOD FROM TOVAR WHERE KOD = :KOD AND TKOD IS NOT NULL';
      DMMag.SQLQ.ParamByName('KOD').AsInteger := TovarKod;
      DMMag.SQLQ.Open;

      if not DMMag.SQLQ.IsEmpty then
        BarcodeStr := Trim(DMMag.SQLQ.FieldByName('TKOD').AsString);

      DMMag.SQLQ.Close;
    except
      on E: Exception do
      begin
        Log('⚠️ Помилка отримання штрих-коду для товару ' +
            IntToStr(TovarKod) + ': ' + E.Message);
        BarcodeStr := '';
      end;
    end;

    // Створюємо товар
    Good := TGood.Create;
    try
      Good.Code := DMMag.QNData.FieldByName('TOVAR').AsString;
      Good.Name := DMMag.QNData.FieldByName('NAZVA').AsString;
      Good.Price := Round(DMMag.QNData.FieldByName('CENA').AsFloat * 100);

      // Штрих-код з TOVAR.TKOD (може бути порожнім)
      Good.Barcode := BarcodeStr;
      if BarcodeStr <> '' then
        Log('Штрих-код товару ' + Good.Name + ': ' + BarcodeStr)
      else
        Log('Штрих-код товару ' + Good.Name + ': відсутній');

      // Податки
      SetLength(Good.Tax, 1);
      Good.Tax[0] := TaxGroup;

      // Створюємо позицію
      GoodItem := TGoodItem.Create;
      try
        GoodItem.Good := Good;
        GoodItem.GoodId := FReceiptAPI.GenerateUUID;
        GoodItem.Quantity := Round(DMMag.QNData.FieldByName('KOL').AsFloat * 1000);
        GoodItem.Sum := Round(DMMag.QNData.FieldByName('SUMMA').AsFloat * 100);
        GoodItem.TotalSum := GoodItem.Sum;
        GoodItem.IsReturn := False;
        GoodItem.IsWinningsPayout := False;

        // Податки для позиції
        SetLength(GoodItem.Taxes, 1);
        GoodItem.Taxes[0] := CreateTaxByGroup(TaxGroup);

        SetLength(Receipt.Goods, Length(Receipt.Goods) + 1);
        Receipt.Goods[High(Receipt.Goods)] := GoodItem;

        Log(Format('Додано товар: %s (штрих-код: %s, податок %d) x %.3f = %.2f грн', [
          Good.Name,
          IfThen(BarcodeStr = '', 'немає', BarcodeStr),
          TaxGroup,
          GoodItem.Quantity / 1000,
          GoodItem.TotalSum / 100
        ]));

      except
        on E: Exception do
        begin
          Log('❌ Помилка створення GoodItem: ' + E.Message);
          FreeAndNil(GoodItem);
          raise;
        end;
      end;

    except
      on E: Exception do
      begin
        Log('❌ Помилка створення Good: ' + E.Message);
        FreeAndNil(Good);
        raise;
      end;
    end;

    DMMag.QNData.Next;
    Inc(i);
  end;

  if Length(Receipt.Goods) = 0 then
    raise Exception.Create('Чек не містить товарів для фіскалізації');

  Log('Успішно додано ' + IntToStr(Length(Receipt.Goods)) + ' товарів');
end;


function TFmChek.DetermineTaxGroupForProduct(ProductCode: string): Integer;
begin
  // Тут може бути логіка визначення податкової групи за кодом товару
  // Наприклад, перевірка в базі даних або за правилами бізнесу

  // За замовчуванням повертаємо 3-ю групу (0% без ПДВ)
  Result := GoodsTaxGroup;   //Result := 3;

  // Приклад логіки:
  {
  if IsExportedProduct(ProductCode) then
    Result := 3 // 0% для експорту
  else if IsMedicalProduct(ProductCode) then
    Result := 4 // Звільнені від ПДВ
  else if IsReducedRateProduct(ProductCode) then
    Result := 2 // Пільгова ставка 7%
  else
    Result := 1 // Стандартна ставка 20%
  }
end;


// ===== ВИПРАВЛЕНИЙ FillPaymentsFromDatabase =====
procedure TFmChek.FillPaymentsFromDatabase(Receipt: TReceipt; CheckID: Integer);
var
  Details: TPaymentDetails;
  PaymentType: string;
  SubType: Integer;
  i: Integer;
  TotalPaymentCents: Integer;
  PaymentIdx: Integer;
  CashAmountCents: Integer;
  CardAmountCents: Integer;
begin
  SetLength(Receipt.Payments, 0);
  PaymentIdx := 0;

  Log('=== FillPaymentsFromDatabase (комбінована оплата) ===');
  Log('CheckID: ' + IntToStr(CheckID));

  if not FDBManager.GetPaymentDetails(CheckID, Details) then
  begin
    Log('❌ Не вдалося отримати деталі оплати');
    Exit;
  end;

  PaymentType := Details.PaymentType;
  SubType := Details.PaymentSubType;

  CashAmountCents := Round(Details.CashAmount * 100);
  CardAmountCents := Round(Details.CardAmount * 100);
  TotalPaymentCents := CashAmountCents + CardAmountCents;

  Log('Тип: ' + PaymentType + ', підтип: ' + IntToStr(SubType));
  Log('Готівка: ' + FloatToStrF(Details.CashAmount, ffNumber, 10, 2) +
      ' грн, Безготівка: ' + FloatToStrF(Details.CardAmount, ffNumber, 10, 2) + ' грн');

  // === КОМБІНОВАНА ОПЛАТА ===
  if CashAmountCents > 0 then
  begin
    SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
    Receipt.Payments[PaymentIdx] := FReceiptAPI.CreatePayment(ptCash, CashAmountCents);
    Receipt.Payments[PaymentIdx].LabelText := 'Готівка';
    Log('✅ Готівка: ' + FloatToStrF(CashAmountCents / 100, ffNumber, 10, 2) + ' грн');
    Inc(PaymentIdx);
  end;

  if CardAmountCents > 0 then
  begin
    case PaymentType of
      'CASHLESS':
        begin
          case SubType of
            1: // Картка (термінал)
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateCashlessPayment(
                  CardAmountCents, TCashlessSubType(SubType));
                Receipt.Payments[PaymentIdx].LabelText := 'Картка';
                Log('✅ Картка');
              end;

            2: // Інтернет-банкінг
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateInternetBankingPayment(
                  CardAmountCents, Details.IBAN, Details.RecipientName, Details.PaymentPurpose);
                Receipt.Payments[PaymentIdx].LabelText := 'Інтернет банкінг';
                Log('✅ Інтернет-банкінг');
              end;

            3: // Інтернет еквайринг
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateCashlessPayment(
                  CardAmountCents, TCashlessSubType(SubType));
                Receipt.Payments[PaymentIdx].LabelText := 'Інтернет еквайринг';
                Log('✅ Інтернет еквайринг');
              end;

            4: // LiqPay
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateIntegratorPayment(
                  CardAmountCents, 'LiqPay');
                Receipt.Payments[PaymentIdx].LabelText := 'Платіж через інтегратора LiqPay';
                Log('✅ LiqPay');
              end;

            5: // Mono
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateIntegratorPayment(
                  CardAmountCents, 'mono');
                Receipt.Payments[PaymentIdx].LabelText := 'Платіж через інтегратора mono';
                Log('✅ Mono');
              end;

            6: // WayForPay
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateIntegratorPayment(
                  CardAmountCents, 'WayForPay');
                Receipt.Payments[PaymentIdx].LabelText := 'Платіж через інтегратора WayForPay';
                Log('✅ WayForPay');
              end;

            7: // NovaPay
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateIntegratorPayment(
                  CardAmountCents, 'NovaPay');
                Receipt.Payments[PaymentIdx].LabelText := 'Платіж через NovaPay';
                Log('✅ NovaPay');
              end;

            8: // EasyPay
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateIntegratorPayment(
                  CardAmountCents, 'EasyPay');
                Receipt.Payments[PaymentIdx].LabelText := 'Платіж через інтегратора EasyPay';
                Log('✅ EasyPay');
              end;

            9: // Подарунковий сертифікат
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateCashlessPayment(
                  CardAmountCents, TCashlessSubType(SubType));
                Receipt.Payments[PaymentIdx].LabelText := 'Подарунковий сертифікат';
                Log('✅ Подарунковий сертифікат');
              end;

            10..17: // Інші підтипи
              begin
                SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
                Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateCashlessPayment(
                  CardAmountCents, TCashlessSubType(SubType));
                Receipt.Payments[PaymentIdx].LabelText := CashlessSubTypeNames[SubType];
                Log('✅ ' + CashlessSubTypeNames[SubType]);
              end;

          else
            SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
            Receipt.Payments[PaymentIdx] := FReceiptAPI.CreateCashlessPayment(
              CardAmountCents, cstCard);
            Receipt.Payments[PaymentIdx].LabelText := 'Картка';
            Log('⚠️ Невідомий підтип ' + IntToStr(SubType) + ', використано картку');
          end;
          Inc(PaymentIdx);
        end;

      'OTHER':
        begin
          SetLength(Receipt.Payments, Length(Receipt.Payments) + 1);
          Receipt.Payments[PaymentIdx] := FReceiptAPI.CreatePayment(ptOther, CardAmountCents);
          Receipt.Payments[PaymentIdx].LabelText := 'Інше';
          Log('✅ Інше');
          Inc(PaymentIdx);
        end;

    else
      Log('⚠️ Невідомий тип: ' + PaymentType);
    end;
  end;

  // Розрахунок загальної суми оплат
  Receipt.TotalPayment := 0;
  for i := 0 to High(Receipt.Payments) do
    if Assigned(Receipt.Payments[i]) then
      Receipt.TotalPayment := Receipt.TotalPayment + Receipt.Payments[i].Value;

  Receipt.Rest := Receipt.TotalPayment - Receipt.TotalSum;

  // ВАЛІДАЦІЯ
  if Receipt.TotalPayment < Receipt.TotalSum then
    raise Exception.CreateFmt(
      'Сума оплат (%.2f грн) менша за суму чека (%.2f грн). Додайте оплату.',
      [Receipt.TotalPayment / 100, Receipt.TotalSum / 100]);

  Log('--- Підсумки ---');
  Log('TotalSum: ' + IntToStr(Receipt.TotalSum) + ' коп');
  Log('TotalPayment: ' + IntToStr(Receipt.TotalPayment) + ' коп');
  Log('Rest: ' + IntToStr(Receipt.Rest) + ' коп');
  Log('Кількість платежів: ' + IntToStr(Length(Receipt.Payments)));
end;

function TFmChek.CalculateTotalSum(Goods: array of TGoodItem): Integer;
var
  i: Integer;
begin
  Result := 0;
  for i := 0 to High(Goods) do
  begin
    if Assigned(Goods[i]) then
      Result := Result + Goods[i].TotalSum;
  end;
  Log('Загальна сума товарів: ' + FloatToStrF(Result/100, ffNumber, 10, 2) + ' грн');
end;

