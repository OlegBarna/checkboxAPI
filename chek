              LText.Add('  Повернення: ' + FormatFloat('0.00', LShiftReport.Taxes[J].ReturnsTurnover / 100) + ' грн');
            LText.Add('');
          end;
        end;
      end;

      LText.Add('═══════════════════════════════════════════════════');
      LText.Add('             ЗВІТ СФОРМОВАНО УСПІШНО');
      LText.Add('═══════════════════════════════════════════════════');

      Result := LText.Text;
    finally
      LText.Free;
    end;
  end;

