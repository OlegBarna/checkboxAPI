      Log('Сума знижок: ' + FloatToStr(LShiftReport.DiscountsSum / 100) + ' грн');
      Log('Сума націнок: ' + FloatToStr(LShiftReport.ExtraChargeSum / 100) + ' грн');

      Log('Дата створення: ' + DateTimeToStr(LShiftReport.CreatedAt));

      // Виводимо інформацію про платежі
      if Length(LShiftReport.Payments) > 0 then
      begin
        Log('--- ПЛАТЕЖІ ---');
        for I := 0 to High(LShiftReport.Payments) do
        begin
          Log('Платіж ' + IntToStr(I+1) + ':');
          Log('  Тип: ' + LShiftReport.Payments[I].PaymentType);
          Log('  Постачальник: ' + LShiftReport.Payments[I].ProviderType);
          Log('  Код: ' + IntToStr(LShiftReport.Payments[I].Code));
          Log('  Назва: ' + LShiftReport.Payments[I].LabelText);
          Log('  Сума продажів: ' + FloatToStr(LShiftReport.Payments[I].SellSum / 100) + ' грн');
          Log('  Сума повернень: ' + FloatToStr(LShiftReport.Payments[I].ReturnSum / 100) + ' грн');
          Log('  Service In: ' + FloatToStr(LShiftReport.Payments[I].ServiceIn / 100) + ' грн');
