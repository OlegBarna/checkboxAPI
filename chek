procedure TFmChek.ChangePaymentType(CheckID: Integer; NewPaymentType: string;
  CashAmount: Double = 0; CardAmount: Double = 0; CardInfo: string = '');
var
  TotalAmount, PaymentTotal: Double;
  SubType: Integer;
begin
  // Позиціонування на чек через менеджер
  if not FDBManager.LocateCheck(CheckID) then
  begin
    ShowMessage('Чек не знайдено!');
    Exit;
  end;

  // Отримання суми чека через менеджер
  TotalAmount := FDBManager.GetCheckTotal(CheckID);
  PaymentTotal := CashAmount + CardAmount;

  // Валідація відповідно до вимог Checkbox API
  if Abs(PaymentTotal - TotalAmount) > 0.01 then
  begin
    ShowMessage(Format(
      'Сума оплати (%.2f) не відповідає сумі чека (%.2f)! ' +
      'Згідно з Checkbox API, суми повинні збігатися.',
      [PaymentTotal, TotalAmount]));
    Exit;
  end;

  // Перевірка коректності типу оплати
  if (NewPaymentType <> 'CASH') and (NewPaymentType <> 'CARD') and (NewPaymentType <> 'MIXED') then
  begin
    ShowMessage('Невірний тип оплати. Допустимі значення: CASH, CARD, MIXED');
    Exit;
  end;

  // Перевірка для змішаної оплати
  if (NewPaymentType = 'MIXED') and ((CashAmount <= 0) or (CardAmount <= 0)) then
  begin
    ShowMessage('Для змішаної оплати обидві суми повинні бути більше 0');
    Exit;
  end;

  // Перевірка для готівкової оплати
  if (NewPaymentType = 'CASH') and (CardAmount > 0) then
  begin
    ShowMessage('Для готівкової оплати сума по картці повинна бути 0');
    Exit;
  end;

  // Перевірка для карткової оплати
  if (NewPaymentType = 'CARD') and (CashAmount > 0) then
  begin
    ShowMessage('Для карткової оплати готівкова сума повинна бути 0');
    Exit;
  end;

  // Визначення підтипу для нової сигнатури UpdatePaymentInfo
  if NewPaymentType = 'CARD' then
    SubType := 1   // CST_CARD
  else
    SubType := 0;  // Для CASH або MIXED (для змішаної краще використовувати окремі платежі)

  // Оновлення даних в БД через менеджер з новою сигнатурою
  // Параметри: CheckID, PaymentType, CashAmount, CardAmount, SubType,
  //            IBAN, RecipientName, PaymentPurpose, CardMask, AuthCode, RRN, ProviderType, TerminalId
  FDBManager.UpdatePaymentInfo(
    CheckID,
    NewPaymentType,
    CashAmount,
    CardAmount,
    SubType,
    '',          // IBAN
    '',          // RecipientName
    '',          // PaymentPurpose
    CardInfo,    // CardMask (використовуємо CardInfo як маску, якщо потрібно)
    '',          // AuthCode
    '',          // RRN
    '',          // ProviderType
    ''           // TerminalId
  );

  Log(Format('Змінено тип оплати для чека %d: %s (Г:%.2f, К:%.2f)',
      [CheckID, NewPaymentType, CashAmount, CardAmount]));
end;



