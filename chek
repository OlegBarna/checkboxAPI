      Log('Округлення продажів у меншу сторону: ' + FloatToStr(LShiftReport.SalesRoundDown / 100) + ' грн');
      Log('Округлення повернень у більшу сторону: ' + FloatToStr(LShiftReport.ReturnsRoundUp / 100) + ' грн');
      Log('Округлення повернень у меншу сторону: ' + FloatToStr(LShiftReport.ReturnsRoundDown / 100) + ' грн');

