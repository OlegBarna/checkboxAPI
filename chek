procedure TFmChek.btnCloseShiftWithReportCurlClick(Sender: TObject);
var
  Response, ZReportResponse: string;
  ShiftStatus: TShiftStatus;
  Success: Boolean;
  ShiftId, ZReportId: string;
  StartTime: TDateTime;
begin
  UpdateShiftStatus(svProcessing);
  // Перевірка стану API та зміни
  if not ValidateAPIState(True, False) then  // RequireShift = True
    Exit;

  // Отримання ID зміни (аналогічно простому закриттю)
  ShiftId := edtShiftId.Text;
  if ShiftId = '' then
  begin
    ShiftId := FReceiptAPI.CurrentShiftId;
    if ShiftId = '' then
      ShiftId := FReceiptAPI.LoadShiftFromFile;
    if ShiftId = '' then
    begin
      ShowMessage('Немає активної зміни для закриття');
      Exit;
    end;
    SynchronizeShiftId(ShiftId);
  end;

  if not ValidateShiftId(ShiftId) then
  begin
    ShowMessage('Недійсний ID зміни');
    Exit;
  end;

  // Підтвердження користувача
  if MessageDlg('Закриття зміни з Z-звітом',
      'Ви впевнені, що хочете закрити зміну та отримати детальний Z-звіт?' + sLineBreak +
      'Ця операція займе більше часу, але надасть повну фінансову звітність.',
      mtConfirmation, [mbYes, mbNo], 0) <> mrYes then
  begin
    Exit;
  end;

  Log('=== ПОЧАТОК ЗАКРИТТЯ ЗМІНИ З Z-ЗВІТОМ ===');
  Log('Shift ID: ' + ShiftId);
  StartTime := Now;

  btnCloseShiftWithReportCurl.Enabled := False;
  Screen.Cursor := crHourGlass;
  ShiftStatus := nil;

  try // ДОДАНО: try для блоку finally
    // КРОК 1: Закриття зміни (аналогічно простому закриттю)
    Log('Крок 1: Закриття зміни...');
    FReceiptAPI.ReceiptsDirectory := receiptspath;
    FReceiptAPI.TempDirectory := temppath;
    Success := FReceiptAPI.CloseShiftSimpleCurl(ShiftId, Response, ShiftStatus);

    if not Success then
    begin
      Log('❌ Помилка закриття зміни: ' + Response);
      ShowMessage('Помилка закриття зміни: ' + Copy(Response, 1, 200));
      Exit;
    end;

    if not Assigned(ShiftStatus) then
    begin
      Log('❌ Помилка: ShiftStatus = nil після успішного виклику');
      ShowMessage('Помилка: не вдалося отримати дані зміни');
      Exit;
    end;

    // КРОК 2: Очікування фінального статусу CLOSED
    Log('Крок 2: Очікування завершення закриття...');
    FreeAndNil(ShiftStatus);

    if not FReceiptAPI.WaitForShiftStatus(ShiftId, 'CLOSED', Response, ShiftStatus, 120) then // 120 сек таймаут
    begin
      Log('❌ Таймаут очікування закриття зміни: ' + Response);
      ShowMessage('Не вдалося завершити закриття зміни вчасно. Спробуйте пізніше.');
      Exit;
    end;

    if not Assigned(ShiftStatus) then
    begin
      Log('❌ Помилка: ShiftStatus = nil після очікування');
      ShowMessage('Помилка: не вдалося отримати фінальний статус зміни');
      Exit;
    end;

    // КРОК 3: Отримання Z-звіту
    Log('Крок 3: Отримання детального Z-звіту...');

    // Отримуємо ID Z-звіту з відповіді
    ZReportId := ExtractZReportIdFromResponse(Response);

    if ZReportId = '' then
    begin
      // Якщо не знайшли в Response, пробуємо отримати з ShiftStatus
      if Assigned(ShiftStatus) and (ShiftStatus.ZReport <> '') then
      begin
        ZReportId := ShiftStatus.ZReport;
        Log('Отримано ZReportId з ShiftStatus: ' + ZReportId);
      end
      else
      begin
        Log('⚠️ Z-звіт не знайдено у відповіді. Спробуємо отримати останній звіт...');
        // Можна додати логіку пошуку останнього Z-звіту для цієї зміни
      end;
    end;

    // КРОК 4: Отримання та збереження різних форматів Z-звіту
    if ZReportId <> '' then
    begin
      Log('Отримання детального Z-звіту ID: ' + ZReportId);

      // 4.1 JSON версія
      if FReceiptAPI.GetZReportCurl(ZReportId, ZReportResponse) then
      begin
        Log('✅ Детальний Z-звіт отримано успішно');
        ParseAndShowZReport(ZReportResponse);
      end
      else
      begin
        Log('⚠️ Не вдалося отримати детальний Z-звіт: ' + FReceiptAPI.LastError);
      end;

      // 4.2 Текстова версія
      GetZReportTextAndSave(ZReportId);

      // 4.3 PNG версія
      GetZReportPNGAndSave(ZReportId);

    end
    else
    begin
      Log('⚠️ ID Z-звіту не знайдено. Детальний звіт недоступний.');
      ShowMessage('Зміну успішно закрито, але детальний Z-звіт недоступний.');
    end;

    // КРОК 5: Фіналізація
    Log('✅ Зміну успішно закрито з отриманням Z-звіту!');
    Log('Серійний номер: ' + IntToStr(ShiftStatus.Serial));
    Log('Час закриття: ' + DateTimeToStr(ShiftStatus.ClosedAt));

    if Assigned(ShiftStatus.Balance) then
    begin
      Log('Фінальний баланс: ' + Format('%.2f грн', [ShiftStatus.Balance.Balance / 100]));
    end;

    // Оновлення інтерфейсу
    btnCloseShiftSimpleCurl.Enabled := False;
    btnCloseShiftWithReportCurl.Enabled := False;
    ClearShiftState;

    Log('Зміну успішно закрито!' + sLineBreak +
               'Z-звіт збережено у різних форматах.' + sLineBreak +
               'Перевірте папку: ' + receiptspath);
    UpdateShiftStatus(svClosed);
  except
    on E: Exception do
    begin
      Log('💥 Виняток при закритті зміни з Z-звітом: ' + E.Message);
      ShowMessage('Критична помилка: ' + E.Message);
    end;
  end; // ЗАКРИТО: try блок
  UpdateAllStatuses;
  // Завершення - тепер це частина основного блоку
  if Assigned(ShiftStatus) then
    FreeAndNil(ShiftStatus);

  btnCloseShiftWithReportCurl.Enabled := True;
  Screen.Cursor := crDefault;

  Log('=== ЗАВЕРШЕННЯ ЗАКРИТТЯ ЗМІНИ З Z-ЗВІТОМ ===');
  Log('Час виконання: ' + IntToStr(SecondsBetween(Now, StartTime)) + ' сек');
end;


// ДОДАЄМО НОВУ ПРОЦЕДУРУ ДЛЯ ПАРСИНГУ ТА ВІДОБРАЖЕННЯ Z-ЗВІТУ
procedure TFmChek.ParseAndShowZReport(const AZReportJSON: string);
var
  JsonParser: TJSONParser;
  JsonData: TJSONObject;
  ZReportInfo: string;
begin
  try
    JsonParser := TJSONParser.Create(AZReportJSON, [joUTF8]);
    try
      JsonData := JsonParser.Parse as TJSONObject;

      // Формуємо зрозумілу інформацію про Z-звіт
      ZReportInfo := 'Z-звіт успішно створено!' + sLineBreak +
                    'ID: ' + JsonData.Get('id', '') + sLineBreak +
                    'Серійний номер: ' + IntToStr(JsonData.Get('serial', 0)) + sLineBreak +
                    'Фіскальний код: ' + JsonData.Get('fiscal_code', '') + sLineBreak +
                    'ID зміни: ' + JsonData.Get('shift_id', '');

      // Додатково можна парсити payments, taxes тощо
      if JsonData.Find('payments') <> nil then
        ZReportInfo := ZReportInfo + sLineBreak + 'Кількість платежів: ' +
          IntToStr(JsonData.Arrays['payments'].Count);

      if JsonData.Find('taxes') <> nil then
        ZReportInfo := ZReportInfo + sLineBreak + 'Кількість податків: ' +
          IntToStr(JsonData.Arrays['taxes'].Count);

      {ShowMessage(ZReportInfo);}
      Log('Z-звіт проаналізовано: ' + Copy(ZReportInfo, 1, 100));

    finally
      JsonData.Free;
    end;
  except
    on E: Exception do
    begin
      Log('Помилка парсингу Z-звіту: ' + E.Message);
      ShowMessage('Z-звіт отримано, але виникла помилка аналізу: ' + E.Message);
    end;
  end;
end;

