procedure TFmChek.btnGetShiftStatusCurlClick(Sender: TObject);
var
  Response: string;
  ShiftStatus: TShiftStatus;
  Success: Boolean;
  ShiftId: string;
begin
  if not ValidateAPIState(True, False) then  // RequireShift = True
    Exit;

  // Отримуємо ID зміни (не Serial)
  ShiftId := edtShiftId.Text;

  // Якщо поле вводу порожнє, намагаємось взяти збережений ID
  if ShiftId = '' then
  begin
    ShiftId := FReceiptAPI.CurrentShiftId; // Це має бути ID, не Serial
    if ShiftId = '' then
      ShiftId := FReceiptAPI.LoadShiftFromFile; // Має повертати ID
    if ShiftId = '' then
    begin
      ShowMessage('Немає активної зміни.');
      Exit;
    end;
    SynchronizeShiftId(ShiftId); // Синхронізуємо всі джерела
  end;

  // Перевіряємо ID, а не Serial
  if not ValidateShiftId(ShiftId) then
  begin
    ShowMessage('Недійсний ID зміни');
    Exit;
  end;

  Log('Перевірка статусу зміни через CURL...');
  Log('Shift ID: ' + ShiftId);

  Success := FReceiptAPI.GetShiftStatusCurl(ShiftId, Response, ShiftStatus);

  if Success and Assigned(ShiftStatus) then
  begin
    Log('Статус зміни отримано через CURL!');
    Log('ID: ' + ShiftStatus.Id);
    Log('Статус: ' + ShiftStatus.Status);
    Log('Серійний номер: ' + IntToStr(ShiftStatus.Serial));
    Log('Z-звіт: ' + ShiftStatus.ZReport);

    if ShiftStatus.Status = 'OPENED' then
    begin
      Log('Зміна відкрита о: ' + DateTimeToStr(ShiftStatus.OpenedAt));
      // Оновлюємо інтерфейс для відкритої зміни
      btnCloseShiftSimpleCurl.Enabled := True;
      btnCloseShiftWithReportCurl.Enabled := True;
    end
    else if ShiftStatus.Status = 'CLOSED' then
    begin
      Log('Зміна закрита о: ' + DateTimeToStr(ShiftStatus.ClosedAt));
      // Додаткова інформація про причину закриття (якщо є)
      if ShiftStatus.EmergencyClose then
      begin
        Log('Аварійне закриття: ' + ShiftStatus.EmergencyCloseDetails);
      end;

      // Деактивуємо кнопки закриття для закритої зміни
      btnCloseShiftSimpleCurl.Enabled := False;
      btnCloseShiftWithReportCurl.Enabled := False;
    end;

    // Додаткова інформація про касу
    if ShiftStatus.CashRegisterId <> '' then
    begin
      Log('ID каси: ' + ShiftStatus.CashRegisterId);
    end;

    // Оновлюємо поле вводу з правильним ID
    if ShiftStatus.Id <> '' then
    begin
      SynchronizeShiftId(ShiftStatus.Id);
    end;

    // Показуємо статус користувачеві
    case ShiftStatus.Status of
      'OPENED':
       begin
        UpdateShiftStatus(svOpened, '№' + IntToStr(ShiftStatus.Serial));
        Log('Зміна відкрита' + sLineBreak +
                   'Номер: ' + IntToStr(ShiftStatus.Serial) + sLineBreak +
                   'Відкрита: ' + DateTimeToStr(ShiftStatus.OpenedAt));
       end;
      'CLOSED':
       begin
        UpdateShiftStatus(svClosed, '№' + IntToStr(ShiftStatus.Serial));
        Log('Зміна закрита' + sLineBreak +
                   'Номер: ' + IntToStr(ShiftStatus.Serial) + sLineBreak +
                   'Закрита: ' + DateTimeToStr(ShiftStatus.ClosedAt));
       end
      else
        begin
         UpdateShiftStatus(svError, ShiftStatus.Status);
         Log('Статус зміни: ' + ShiftStatus.Status + sLineBreak +
                   'Номер: ' + IntToStr(ShiftStatus.Serial));
        end;
    end;

  end
  else
  begin
    Log('Помилка отримання статусу зміни через CURL: ' + Response);

    // Детальніша обробка помилок
    if Pos('"message":"', Response) > 0 then
      Log('Сервер повернув помилку: ' + Response)
    else if Pos('Not Found', Response) > 0 then
      Log('Зміну не знайдено. Перевірте ID зміни.')
    else if Pos('Unauthorized', Response) > 0 then
      Log('Помилка авторизації. Токен недійсний.');

    ShowMessage('Помилка отримання статусу зміни через CURL: ' + Copy(Response, 1, 200));
  end;
  UpdateAllStatuses;
  if Assigned(ShiftStatus) then
    FreeAndNil(ShiftStatus);
end;

procedure TFmChek.btnGetXReportClick(Sender: TObject);
var
  LResponse: string;
  LShiftReport: TShiftReport;
  LTextReport: string;
  LReportFile: string;
  LPngFileName: string;
  I: Integer; // Додано оголошення змінної I

  // Функція повинна бути оголошена перед використанням
  function GenerateXReportText(LShiftReport: TShiftReport): string;
  var
    J: Integer; // Використовуємо іншу змінну для уникнення конфлікту
    LText: TStringList;
  begin
    LText := TStringList.Create;
    try
      // Заголовок
      LText.Add('═══════════════════════════════════════════════════');
      LText.Add('                   Х-ЗВІТ');
      LText.Add('═══════════════════════════════════════════════════');
      LText.Add('');

      // Основна інформація
      LText.Add('▸ ID звіту: ' + LShiftReport.Id);
      LText.Add('▸ Серійний номер: ' + IntToStr(LShiftReport.Serial));
      LText.Add('▸ Час створення: ' + DateTimeToStr(LShiftReport.CreatedAt));
      LText.Add('');

      // Статистика чеків
      LText.Add('────────────── СТАТИСТИКА ЧЕКІВ ──────────────');
      LText.Add('Чеків продажу:        ' + IntToStr(LShiftReport.SellReceiptsCount));
      LText.Add('Чеків повернення:     ' + IntToStr(LShiftReport.ReturnReceiptsCount));
      LText.Add('Чеків видачі готівки: ' + IntToStr(LShiftReport.CashWithdrawalReceiptsCount));
      LText.Add('');

      // Фінансові підсумки
      LText.Add('───────────────── ФІНАНСИ ───────────────────');
      LText.Add('Початкова сума:       ' + FormatFloat('0.00', LShiftReport.Initial / 100) + ' грн');
      LText.Add('Кінцевий баланс:      ' + FormatFloat('0.00', LShiftReport.Balance / 100) + ' грн');
      LText.Add('Сума знижок:          ' + FormatFloat('0.00', LShiftReport.DiscountsSum / 100) + ' грн');
      LText.Add('Сума націнок:         ' + FormatFloat('0.00', LShiftReport.ExtraChargeSum / 100) + ' грн');
      LText.Add('');

      // Округлення
      LText.Add('──────────────── ОКРУГЛЕННЯ ─────────────────');
      LText.Add('Продажі (вгору):      ' + FormatFloat('0.00', LShiftReport.SalesRoundUp / 100) + ' грн');
      LText.Add('Продажі (вниз):       ' + FormatFloat('0.00', LShiftReport.SalesRoundDown / 100) + ' грн');
      LText.Add('Повернення (вгору):   ' + FormatFloat('0.00', LShiftReport.ReturnsRoundUp / 100) + ' грн');
      LText.Add('Повернення (вниз):    ' + FormatFloat('0.00', LShiftReport.ReturnsRoundDown / 100) + ' грн');
      LText.Add('');

      // Платежі
      if Length(LShiftReport.Payments) > 0 then
      begin
        LText.Add('───────────────── ПЛАТЕЖІ ───────────────────');
        for J := 0 to High(LShiftReport.Payments) do
        begin
          LText.Add('● ' + LShiftReport.Payments[J].LabelText + ':');
          LText.Add('  Продажі:    ' + FormatFloat('0.00', LShiftReport.Payments[J].SellSum / 100) + ' грн');
          LText.Add('  Повернення: ' + FormatFloat('0.00', LShiftReport.Payments[J].ReturnSum / 100) + ' грн');
          if LShiftReport.Payments[J].ServiceIn > 0 then
            LText.Add('  Service In: ' + FormatFloat('0.00', LShiftReport.Payments[J].ServiceIn / 100) + ' грн');
          if LShiftReport.Payments[J].ServiceOut > 0 then
            LText.Add('  Service Out:' + FormatFloat('0.00', LShiftReport.Payments[J].ServiceOut / 100) + ' грн');
          LText.Add('');
        end;
      end;

      // Податки
      if Length(LShiftReport.Taxes) > 0 then
      begin
        LText.Add('───────────────── ПОДАТКИ ───────────────────');
        for J := 0 to High(LShiftReport.Taxes) do
        begin
          if (LShiftReport.Taxes[J].SalesTurnover > 0) or (LShiftReport.Taxes[J].ReturnsTurnover > 0) then
          begin
            LText.Add('● ' + LShiftReport.Taxes[J].LabelText + ' (' + LShiftReport.Taxes[J].Symbol + '):');
            LText.Add('  Ставка:     ' + FormatFloat('0.0', LShiftReport.Taxes[J].Rate) + '%');
            LText.Add('  Оборот:     ' + FormatFloat('0.00', LShiftReport.Taxes[J].SalesTurnover / 100) + ' грн');
