          Log('  Видача готівки: ' + FloatToStr(LShiftReport.Payments[I].CashWithdrawal / 100) + ' грн');
          Log('  Комісія видачі: ' + FloatToStr(LShiftReport.Payments[I].CashWithdrawalCommission / 100) + ' грн');
        end;
      end
      else
