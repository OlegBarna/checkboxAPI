function TFmChek.ValidateIBAN(const AIBAN: string): Boolean;
begin
  // UA + 27 цифр = 29 символів
  Result := (Length(AIBAN) = 29) and
            (Copy(AIBAN, 1, 2) = 'UA') and
            (StrToIntDef(Copy(AIBAN, 3, 27), -1) >= 0);
  // Примітка: повна mod-97 валідація — окремо якщо потрібно
end;


function TFmChek.ValidateCardMask(const AMask: string): Boolean;
var
  i, DigitCount: Integer;
begin
  Result := False;
  if (Length(AMask) < 4) or (Length(AMask) > 19) then Exit;

  DigitCount := 0;
  for i := 1 to Length(AMask) do
  begin
    if AMask[i] in ['0'..'9'] then Inc(DigitCount)
    else if AMask[i] <> '*' then Exit;
  end;
  Result := DigitCount >= 4; // Мінімум 4 цифри
end;


function TFmChek.ValidateRRN(const ARRN: string): Boolean;
begin
  Result := (Length(ARRN) = 12) and (StrToInt64Def(ARRN, -1) >= 0);
end;

function TFmChek.ValidateAuthCode(const ACode: string): Boolean;
begin
  Result := (Length(ACode) = 6) and (StrToIntDef(ACode, -1) >= 0);
end;

// ===== ВИПРАВЛЕНИЙ ValidatePaymentFields =====
function TFmChek.ValidatePaymentFields: Boolean;
var
  SubType: Integer;
begin
  Result := False;

  if cmbPaymentType.ItemIndex = 1 then // Безготівка
  begin
    SubType := SubTypeIndexToCode(cmbCashlessSubType.ItemIndex);

    // Валідація залежно від підтипу
    case SubType of
      1, 3: // Картка, Інтернет еквайринг
        begin
          if (edtCardMask.Text <> '') and not ValidateCardMask(edtCardMask.Text) then
          begin
            ShowMessage('Невірна маска картки. Формат: ****1234 або 1234');
            edtCardMask.SetFocus;
            Exit;
          end;
          if (edtAuthCode.Text <> '') and not ValidateAuthCode(edtAuthCode.Text) then
          begin
            ShowMessage('Код авторизації — 6 цифр');
            edtAuthCode.SetFocus;
            Exit;
          end;
          if (edtRRN.Text <> '') and not ValidateRRN(edtRRN.Text) then
          begin
            ShowMessage('RRN — 12 цифр');
            edtRRN.SetFocus;
            Exit;
          end;
        end;

      2: // Інтернет-банкінг
        begin
          if (edtIBAN.Text <> '') and not ValidateIBAN(edtIBAN.Text) then
          begin
            ShowMessage('IBAN має формат UA + 27 цифр (29 символів)');
            edtIBAN.SetFocus;
            Exit;
          end;
        end;

      4..8: // Інтегратори (LiqPay, Mono, WayForPay, NovaPay, EasyPay)
        begin
          // AuthCode та RRN опціонально
          if (edtAuthCode.Text <> '') and not ValidateAuthCode(edtAuthCode.Text) then
          begin
            ShowMessage('Код авторизації — 6 цифр');
            edtAuthCode.SetFocus;
            Exit;
          end;
          if (edtRRN.Text <> '') and not ValidateRRN(edtRRN.Text) then
          begin
            ShowMessage('RRN — 12 цифр');
            edtRRN.SetFocus;
            Exit;
          end;
        end;

      9: // Подарунковий сертифікат
        begin
          if (edtCardMask.Text <> '') and not ValidateCardMask(edtCardMask.Text) then
          begin
            ShowMessage('Невірний номер сертифіката');
            edtCardMask.SetFocus;
            Exit;
          end;
        end;

      10..17: // Талон та інші — без додаткових полів
        begin
          // Додаткова валідація не потрібна
        end;
    end;
  end;

  Result := True;
end;

// ===== ВИПРАВЛЕНИЙ SavePaymentToDB (без помилки Details) =====
procedure TFmChek.SavePaymentToDB(CheckID: Integer);
var
  PaymentType: string;
  SubType: Integer;
begin
  if CheckID <= 0 then Exit;

  PaymentType := PaymentTypeIndexToStr(cmbPaymentType.ItemIndex);
  SubType := 0;

  if PaymentType = 'CASHLESS' then
    SubType := SubTypeIndexToCode(cmbCashlessSubType.ItemIndex);

  // Передаємо суму з поточного чека, а не з Details
  if PaymentType = 'CASH' then
    FDBManager.UpdatePaymentInfo(CheckID, PaymentType,
      DMMag.QChekSUMMA.AsFloat, 0, SubType,
      edtIBAN.Text, edtRecipientName.Text, memPaymentPurpose.Text,
      edtCardMask.Text, edtAuthCode.Text, edtRRN.Text,
      cmbProvider.Text, '')
  else if PaymentType = 'CASHLESS' then
    FDBManager.UpdatePaymentInfo(CheckID, PaymentType,
      0, DMMag.QChekSUMMA.AsFloat, SubType,
      edtIBAN.Text, edtRecipientName.Text, memPaymentPurpose.Text,
      edtCardMask.Text, edtAuthCode.Text, edtRRN.Text,
      cmbProvider.Text, '')
  else // OTHER
    FDBManager.UpdatePaymentInfo(CheckID, PaymentType,
      DMMag.QChekSUMMA.AsFloat, 0, 0,
      edtIBAN.Text, edtRecipientName.Text, memPaymentPurpose.Text,
      edtCardMask.Text, edtAuthCode.Text, edtRRN.Text,
      cmbProvider.Text, '');
end;

