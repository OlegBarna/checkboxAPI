// ===== ВИПРАВЛЕНИЙ ОБРОБНИК cmbPaymentTypeChange =====
procedure TFmChek.cmbPaymentTypeChange(Sender: TObject);
var
  PaymentTypeStr: string;
  CheckID: Integer;
begin
  // Захист від рекурсії
  if FUpdatingPaymentType then Exit;

  // Захист від програмних змін (реагуємо тільки на дії користувача)
  if not cmbPaymentType.Focused then Exit;

  FUpdatingPaymentType := True;
  try
    PaymentTypeStr := PaymentTypeIndexToStr(cmbPaymentType.ItemIndex);
    Log('Зміна типу оплати: ' + PaymentTypeStr);

    if not FDBManager.CanModifyCheck then
    begin
      // Відкат — повертаємо старе значення
      LoadPaymentToUI(DMMag.QChekKOD.AsInteger);
      Exit;
    end;

    case cmbPaymentType.ItemIndex of
      0: begin // Готівка
           cmbCashlessSubType.Visible := False;
           gbPaymentDetails.Visible := False;
           if not DMMag.QChekKOD.IsNull then
             FDBManager.UpdatePaymentInfo(DMMag.QChekKOD.AsInteger,
               'CASH', DMMag.QChekSUMMA.AsFloat, 0, 0);
         end;

      1: begin // Безготівка
           cmbCashlessSubType.Visible := True;
           cmbCashlessSubType.ItemIndex := 0; // Картка за замовчуванням
           UpdatePaymentUIVisibility;
         end;

      2: begin // Інше
           cmbCashlessSubType.Visible := False;
           gbPaymentDetails.Visible := False;
           if not DMMag.QChekKOD.IsNull then
             FDBManager.UpdatePaymentInfo(DMMag.QChekKOD.AsInteger,
               'OTHER', DMMag.QChekSUMMA.AsFloat, 0, 0);
         end;
    end;

  finally
    FUpdatingPaymentType := False;
  end;
end;

// ===== ВИПРАВЛЕНИЙ ОБРОБНИК edtCardMaskChange =====
procedure TFmChek.edtCardMaskChange(Sender: TObject);
var
  S: string;
  i: Integer;
begin
  if FUpdatingPaymentType then Exit;

  S := edtCardMask.Text;

  // Фільтруємо: тільки * та 0-9
  for i := Length(S) downto 1 do
    if not (S[i] in ['*', '0'..'9']) then
      Delete(S, i, 1);

  // Обмежуємо довжину 19 символів
  if Length(S) > 19 then
    S := Copy(S, 1, 19);

  // Встановлюємо відфільтроване значення
  if S <> edtCardMask.Text then
  begin
    edtCardMask.Text := S;
    edtCardMask.SelStart := Length(S);
  end;
end;

// ===== ВИПРАВЛЕНИЙ ОБРОБНИК edtIBANChange =====
procedure TFmChek.edtIBANChange(Sender: TObject);
var
  S: string;
  i: Integer;
begin
  if FUpdatingPaymentType then Exit;

  S := UpperCase(edtIBAN.Text);

  // Фільтруємо: тільки U, A, 0-9
  for i := Length(S) downto 1 do
    if not (S[i] in ['U', 'A', '0'..'9']) then
      Delete(S, i, 1);

  // Автоматично додаємо 'UA' на початку, якщо є дані
  if (Length(S) > 0) and (Copy(S, 1, 2) <> 'UA') then
  begin
    if S[1] = 'A' then
      S := 'U' + S
    else if S[1] <> 'U' then
      S := 'UA' + S;
  end;

  // Обмежуємо довжину 29 символів
  if Length(S) > 29 then
    S := Copy(S, 1, 29);

  if S <> edtIBAN.Text then
  begin
    edtIBAN.Text := S;
    edtIBAN.SelStart := Length(S);
  end;
end;

