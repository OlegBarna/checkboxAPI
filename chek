// ===== ВИПРАВЛЕНА LoadPaymentToUI (додана конвертація 'CARD' → 'CASHLESS') =====
procedure TFmChek.LoadPaymentToUI(CheckID: Integer);
var
  Details: TPaymentDetails;
  PaymentTypeStr: string;
begin
  if CheckID <= 0 then Exit;
  if not FDBManager.GetPaymentDetails(CheckID, Details) then Exit;

  FUpdatingPaymentType := True;
  try
    // Конвертація старого типу 'CARD' → 'CASHLESS' для зворотної сумісності
    PaymentTypeStr := Details.PaymentType;
    if PaymentTypeStr = 'CARD' then
      PaymentTypeStr := 'CASHLESS';

    // Основний тип
    cmbPaymentType.ItemIndex := PaymentTypeStrToIndex(PaymentTypeStr);

    // Підтип (тільки для безготівки)
    if (PaymentTypeStr = 'CASHLESS') or (Details.PaymentType = 'CARD') then
    begin
      cmbCashlessSubType.ItemIndex := SubTypeCodeToIndex(Details.PaymentSubType);
      // Заповнюємо додаткові поля
      edtCardMask.Text := Details.CardMask;
      edtAuthCode.Text := Details.AuthCode;
      edtRRN.Text := Details.RRN;
      cmbProvider.Text := Details.ProviderType;
      edtIBAN.Text := Details.IBAN;
      edtRecipientName.Text := Details.RecipientName;
      memPaymentPurpose.Text := Details.PaymentPurpose;
    end;

    UpdatePaymentUIVisibility;

  finally
    FUpdatingPaymentType := False;
  end;
end;

function TFmChek.IsTaxGroupValid(TaxGroup: Integer): Boolean;
const
  ValidTaxGroups: array[0..6] of Integer = (1, 2, 3, 4, 5,8, 99);
var
  i: Integer;
begin
  Result := False;
  for i := Low(ValidTaxGroups) to High(ValidTaxGroups) do
    if ValidTaxGroups[i] = TaxGroup then
    begin
      Result := True;
      Break;
    end;
end;

initialization
  {$I chek.lrs}

end.
