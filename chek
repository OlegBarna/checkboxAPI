// Кнопка для експорту
procedure TFmChek.btnWarrantyExportClick(Sender: TObject);
var
  WarrantyDataSet: TDataSet;
  CheckNumber, CheckDate, FullFileName: string;
begin
  WarrantyDataSet := FDBManager.GetWarrantyProducts(
    DMMag.QChekKOD.AsInteger,
    DMMag.QChekSCHET.AsInteger
  );

  if Assigned(WarrantyDataSet) and (WarrantyDataSet.RecordCount > 0) then
  begin
    // Використовуємо номер ЧЕКА (не рахунку)
    if DMMag.QChekNOMER.IsNull then
      CheckNumber := 'без номера'
    else
      CheckNumber := DMMag.QChekNOMER.AsString;

    // Використовуємо поточну дату
    CheckDate := FormatDateTime('dd.mm.yyyy', Date);

    // Формуємо повне ім'я файлу
    FullFileName := FpsExporter.ExportPath + 'Гарантія_чек_' + CheckNumber + '.ods';

    if FpsExporter.ExportWarrantyProducts(WarrantyDataSet,
       'Гарантія_чек_' + CheckNumber, efODS,
       CheckNumber,
       CheckDate) then
    begin
      // Відкриваємо файл в застосунку за замовчуванням
      if FileExists(FullFileName) then
        OpenDocument(FullFileName)
      else
        ShowMessage('Файл не знайдено: ' + FullFileName);
    end
    else
      ShowMessage('Помилка експорту гарантійних товарів!');
  end
  else
  begin
    MessageDlg('Не вдалося отримати гарантійні товарів', mtError, [mbOK], 0);
  end;
end;

